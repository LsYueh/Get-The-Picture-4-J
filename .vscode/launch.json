    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "type": "java",
            "name": "Forge",
            "request": "launch",
            "mainClass": "io.github.lsyueh.getthepicture.cli.Forge",
            "vmArgs": "-Dforge.debug=true",
            "projectName": "cli",
            "args": [
                "--copybook", "${workspaceFolder}/cli/src/main/resources/m01.cpy"
            ]
        }
    ]
}